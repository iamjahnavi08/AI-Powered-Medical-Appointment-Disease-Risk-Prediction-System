# Environment: development | production
APP_ENV=development

# Secret used to sign session cookies.
# In production, use a long random value (>= 32 chars).
APP_SESSION_SECRET=change-me-to-a-long-random-secret

# SQLite path (default is data/app/app.db).
# APP_DB_PATH=data/app/app.db

# CSRF header name used by the frontend JS when calling POST/PUT/PATCH/DELETE endpoints.
# APP_CSRF_HEADER=X-CSRF-Token

# Simple rate limiting (per-IP per-scope).
APP_RATE_LIMIT_WINDOW_S=300
APP_RATE_LIMIT_MAX=20
